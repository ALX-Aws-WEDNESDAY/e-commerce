# =============================================================================
# Production Environment Variables — Example
# Copy this file to .env.production and fill in the required values.
# NEVER commit .env.production with real secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# VITE_API_BASE_URL (REQUIRED)
# The full invoke URL of the AWS API Gateway stage that fronts all backend
# microservices.  No trailing slash.
# Example: https://abc123xyz.execute-api.eu-west-1.amazonaws.com/prod
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=

# -----------------------------------------------------------------------------
# VITE_ENABLE_MOCKS (optional, default: "false")
# Set to "true" to activate MSW (Mock Service Worker) in the browser.
# Useful for smoke-testing the UI without a live backend.
# Should be "false" in real production deployments.
# Example: false
# -----------------------------------------------------------------------------
VITE_ENABLE_MOCKS=false

# -----------------------------------------------------------------------------
# VITE_APP_VERSION (optional, injected by CI)
# A human-readable version string, typically the git SHA or tag injected
# during the CI/CD build step.  Used for diagnostics / Sentry releases.
# Example: a1b2c3d4  (git SHA)  or  v1.4.2  (semver tag)
# -----------------------------------------------------------------------------
VITE_APP_VERSION=
